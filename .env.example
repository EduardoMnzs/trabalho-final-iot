# Copie para .env (docker compose lê automaticamente)

# ===== Tempo simulado =====
# 60 = 1s real equivale a 60s simulados (1 dia simulado em 24min reais)
TIME_SCALE=60
SIM_SEED=42

# ===== Detector FLAPPING (event-driven) =====
FLAPPING_WINDOW_SEC=120
FLAPPING_MAX_TRANSITIONS=6
FLAPPING_COOLDOWN_SEC=60

# ===== Detector STUCK (scanner periódico) =====
STUCK_OCCUPIED_THRESHOLD_SEC=28800
STUCK_FREE_THRESHOLD_SEC=86400
STUCK_SCAN_INTERVAL_MS=30000
SNAPSHOT_INTERVAL_MS=10000

# ===== Recomendação =====
RECOMMENDATION_THRESHOLD=0.90
RECOMMENDATION_COOLDOWN_SEC=300
