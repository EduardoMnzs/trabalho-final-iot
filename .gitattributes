# Normaliza line endings — sempre LF no repo, qualquer SO no checkout.
* text=auto eol=lf

# Arquivos consumidos por containers Linux precisam SEMPRE de LF.
Dockerfile          text eol=lf
*.sh                text eol=lf
*.conf              text eol=lf
docker-compose.yml  text eol=lf

# Binários — não tocar.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
